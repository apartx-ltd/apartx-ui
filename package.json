{
  "name": "apartx-ui",
  "version": "0.1.0",
  "type": "module",
  "description": "ApartX Svelte 5 UI Kit — themeable design system, source-based (no build step)",
  "svelte": "./src/lib/index.ts",
  "types": "./src/lib/index.ts",
  "exports": {
    ".": {
      "svelte": "./src/lib/index.ts",
      "types": "./src/lib/index.ts"
    },
    "./structure": {
      "svelte": "./src/lib/ui/structure/index.ts",
      "types": "./src/lib/ui/structure/index.ts"
    },
    "./display": {
      "svelte": "./src/lib/ui/display/index.ts",
      "types": "./src/lib/ui/display/index.ts"
    },
    "./data": {
      "svelte": "./src/lib/ui/data/index.ts",
      "types": "./src/lib/ui/data/index.ts"
    },
    "./forms": {
      "svelte": "./src/lib/ui/forms/index.ts",
      "types": "./src/lib/ui/forms/index.ts"
    },
    "./overlays": {
      "svelte": "./src/lib/ui/overlays/index.ts",
      "types": "./src/lib/ui/overlays/index.ts"
    },
    "./hooks": {
      "svelte": "./src/lib/hooks/index.ts",
      "types": "./src/lib/hooks/index.ts"
    },
    "./theme": {
      "types": "./src/lib/theme/index.ts",
      "default": "./src/lib/theme/index.ts"
    },
    "./styles/*": "./src/lib/styles/*"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "peerDependencies": {
    "bits-ui": "^2.18.0",
    "svelte": "^5.0.0",
    "svelte-fa": "^4.0.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@internationalized/date": "^3.12.1",
    "@material/material-color-utilities": "^0.4.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^6.0.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.48.5",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.2.4",
    "bits-ui": "^2.18.0",
    "marked": "^18.0.4",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "svelte-fa": "^4.0.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.2"
  }
}
